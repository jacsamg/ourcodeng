{
  "name": "ourcodeng",
  "version": "2.0.0",
  "license": "MIT",
  "author": "Jacob Samuel G.",
  "homepage": "https://github.com/jacsamg/ourcodeng",
  "description": "Personal libraries for Angular",
  "private": true,
  "type": "module",
  "workspaces": [
    "projects/*"
  ],
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "test": "npm run test --workspaces",
    "publish:fire": "cd dist/fire && npm publish && cd ../.."
  },
  "dependencies": {
    "@angular/common": "^21.0.5",
    "@angular/compiler": "^21.0.5",
    "@angular/core": "^21.0.5",
    "@angular/forms": "^21.0.5",
    "@angular/platform-browser": "^21.0.5",
    "@angular/router": "^21.0.5",
    "rxjs": "^7.8.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.5",
    "@biomejs/biome": "^2.1.3",
    "@types/jasmine": "^5.1.8",
    "ng-packagr": "^21.0.1",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3"
  }
}
